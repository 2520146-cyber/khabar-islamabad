# ═══════════════════════════════════════════════════════════════════
# KHABAR ISLAMABAD — Environment Configuration
# Generated: July 2026
# ═══════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────
# SQLite for development (no installation needed)
DATABASE_URL="file:./dev.db"

# ── Authentication ────────────────────────────────────────────────
# NextAuth secret (generate: openssl rand -base64 32)
NEXTAUTH_SECRET="khabar-islamabad-super-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (get from: https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── AI / Groq (Free & Fast) ───────────────────────────────────────
# Groq API Key — free at https://console.groq.com/keys
GROQ_API_KEY="your-groq-api-key-here"

# ── Translation ──────────────────────────────────────────────────
# Google Translate API (Cloud Translation v3)
GOOGLE_TRANSLATE_API_KEY=""

# ── Media / Cloudinary ───────────────────────────────────────────
# Cloudinary for image uploads (https://cloudinary.com)
CLOUDINARY_URL=""

# ── Search / Meilisearch ─────────────────────────────────────────
# Meilisearch instance (https://meilisearch.com or self-hosted)
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY=""

# ── Weather (Open-Meteo — FREE, no key needed) ──────────────────
# Islamabad coordinates: lat 33.6844, lon 73.0479
OPEN_METEO_URL="https://api.open-meteo.com/v1/forecast"

# ── Prayer Times (Aladhan — FREE, no key needed) ────────────────
ALADHAN_API_URL="https://api.aladhan.com/v1/timings"

# ── Site Configuration ──────────────────────────────────────────
NEXT_PUBLIC_SITE_NAME="Khabar Islamabad"
NEXT_PUBLIC_SITE_URL="https://khabar.islamabad.pk"
NEXT_PUBLIC_SITE_DESCRIPTION="Pakistan's most trusted digital newsroom"
NEXT_PUBLIC_SITE_LOCALE="en"
NEXT_PUBLIC_CITY="Islamabad"
NEXT_PUBLIC_LATITUDE="33.6844"
NEXT_PUBLIC_LONGITUDE="73.0479"
