# ═══════════════════════════════════════════════════════════════════
# KHABAR ISLAMABAD — Environment Variables Template
# Copy this file to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/khabar_islamadb?schema=public"

# ── Authentication ────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth credentials (optional)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── AI / Gemini ──────────────────────────────────────────────────
# Gemini API Key for AI features (summaries, translations, SEO, FAQ)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_API_URL="https://generativelanguage.googleapis.com/v1beta/models/gemini-flash-latest:generateContent"
GEMINI_PROJECT_ID="projects/your-project-id"

# ── Translation ──────────────────────────────────────────────────
# Google Translate API (Cloud Translation v3)
# Note: Gemini AI is used as fallback when this is not set
GOOGLE_TRANSLATE_API_KEY=""

# ── Media / Cloudinary ───────────────────────────────────────────
# Cloudinary for image uploads and transformations
# Get from: https://cloudinary.com
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"

# ── Search / Meilisearch ─────────────────────────────────────────
# Meilisearch instance for full-text search
# Get from: https://meilisearch.com or self-host
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="your-meilisearch-master-key"

# ── Weather (Open-Meteo — FREE, no key needed) ──────────────────
# Islamabad coordinates: lat 33.6844, lon 73.0479
# API URL: https://api.open-meteo.com/v1/forecast
OPEN_METEO_URL="https://api.open-meteo.com/v1/forecast"

# ── Prayer Times (Aladhan — FREE, no key needed) ────────────────
# API URL: https://api.aladhan.com/v1/timings
ALADHAN_API_URL="https://api.aladhan.com/v1/timings"

# ── Site Configuration ──────────────────────────────────────────
NEXT_PUBLIC_SITE_NAME="Khabar Islamabad"
NEXT_PUBLIC_SITE_URL="https://khabar.islamabad.pk"
NEXT_PUBLIC_SITE_DESCRIPTION="Pakistan's most trusted digital newsroom"
NEXT_PUBLIC_SITE_LOCALE="en"
NEXT_PUBLIC_CITY="Islamabad"
NEXT_PUBLIC_LATITUDE="33.6844"
NEXT_PUBLIC_LONGITUDE="73.0479"
